# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/contentcraft"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"

# Anthropic AI
ANTHROPIC_API_KEY="sk-ant-..."
AI_PROVIDER="anthropic"
AI_MODEL="claude-sonnet-4-6"
AI_EMBED_MODEL="voyage-2"  # or use a local embedding approach

# S3-compatible storage (AWS S3 or Cloudflare R2)
S3_BUCKET="contentcraft"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_ENDPOINT=""  # Leave empty for AWS, set for R2: https://ACCOUNT_ID.r2.cloudflarestorage.com

# Email (optional — for reviewer notifications)
EMAIL_FROM="noreply@contentcraft.app"
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="user"
EMAIL_SERVER_PASSWORD="password"

# App config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
